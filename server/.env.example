# =============================================================================
# SayIt — Environment Variables
# =============================================================================
# Copy to .env and fill in your values, OR pass directly via docker env.
#
# ZERO-CONFIG: Leave everything empty → pure ASR mode (no LLM polishing).
# MINIMAL:     Fill one LLM provider → auto-enables text polishing.
# =============================================================================

# ─── LLM Text Polishing ─────────────────────────────────────────────
# Fill the API key for your preferred provider. SayIt auto-detects
# which provider to use based on which key is set.
# To explicitly choose: set SAYIT_LLM_PROVIDER (openai/azure/groq/ollama)

# OpenAI / OpenAI-compatible API (DeepSeek, Together, local proxies, etc.)
# SAYIT_OPENAI_API_KEY=sk-xxx
# SAYIT_OPENAI_BASE_URL=https://api.openai.com   # Change for compatible APIs
# SAYIT_OPENAI_MODEL=gpt-4o-mini                  # Default model

# Azure OpenAI
# SAYIT_AZURE_API_KEY=
# SAYIT_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# SAYIT_AZURE_DEPLOYMENT=gpt-4o

# Groq
# SAYIT_GROQ_API_KEY=gsk-xxx
# SAYIT_GROQ_MODEL=qwen/qwen3-32b

# Ollama (local, no API key needed)
# SAYIT_LLM_PROVIDER=ollama                       # Must set explicitly
# SAYIT_OLLAMA_URL=http://host.docker.internal:11434/api/generate
# SAYIT_OLLAMA_MODEL=qwen2.5:7b

# ─── Web Demo LLM (optional) ────────────────────────────────────────
# By default, web demo uses the same provider as desktop.
# Set these to use a different (e.g. cheaper) provider for the demo.
# SAYIT_WEB_DEMO_LLM_PROVIDER=groq
# SAYIT_WEB_DEMO_GROQ_API_KEY=

# ─── Admin Dashboard ────────────────────────────────────────────────
# Default: admin / sayit — change in production!
# SAYIT_ADMIN_USERNAME=admin
# SAYIT_ADMIN_PASSWORD=sayit

# ─── ASR ─────────────────────────────────────────────────────────────
# SAYIT_ASR_LANGUAGE=Chinese                      # Chinese / English / Cantonese

# ─── Advanced ────────────────────────────────────────────────────────
# SAYIT_WEB_DEMO_ENABLED=true
# SAYIT_LOG_LEVEL=INFO
# SAYIT_CORS_ORIGINS=*                            # Comma-separated origins
# SAYIT_TLS_ENABLED=true                          # Disable if behind ALB/nginx
# SAYIT_DB_URL=                                   # PostgreSQL URL (default: SQLite)
